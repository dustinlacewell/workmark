{
  "name": "workmark-vsc",
  "displayName": "Workmark Dashboard",
  "description": "Visual dashboard for workspace commands",
  "version": "1.1.0",
  "private": true,
  "publisher": "ldlework",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workspace-dashboard.refresh",
        "title": "Refresh Commands",
        "icon": "$(refresh)",
        "category": "Workspace"
      },
      {
        "command": "workspace-dashboard.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)",
        "category": "Workspace"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workspace-dashboard.collapseAll",
          "when": "view == workspace-dashboard.sidebar",
          "group": "navigation"
        },
        {
          "command": "workspace-dashboard.refresh",
          "when": "view == workspace-dashboard.sidebar",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workspace-dashboard",
          "title": "Workspace",
          "icon": "resources/dashboard.svg"
        }
      ]
    },
    "views": {
      "workspace-dashboard": [
        {
          "id": "workspace-dashboard.sidebar",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Workmark",
      "properties": {
        "workmark.runner": {
          "type": "string",
          "default": "",
          "description": "Command used to invoke ws (e.g. \"pnpm ws\", \"npx ws\"). Leave empty to use \"ws\" directly."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs && vite build",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "dev": "concurrently \"node esbuild.mjs --watch\" \"vite build --watch\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
